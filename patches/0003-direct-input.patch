+            virtualKeyboardLayout = virtualKeyboardLayout
         )
     }
 }
diff --git a/app/src/main/java/com/atharok/btremote/ui/views/keyboard/VirtualKeyboard.kt b/app/src/main/java/com/atharok/btremote/ui/views/keyboard/VirtualKeyboard.kt
