diff --git a/app/src/main/java/com/atharok/btremote/domain/entities/remoteInput/keyboard/AndroidKeyMapper.kt b/app/src/main/java/com/atharok/btremote/domain/entities/remoteInput/keyboard/AndroidKeyMapper.kt
new file mode 100644
index 0000000..cfc5f1c
--- /dev/null
+++ b/app/src/main/java/com/atharok/btremote/domain/entities/remoteInput/keyboard/AndroidKeyMapper.kt
@@ -0,0 +1,94 @@
+package com.atharok.btremote.domain.entities.remoteInput.keyboard
+
+import android.util.Log
+import androidx.compose.ui.input.key.Key
+import com.atharok.btremote.common.utils.REMOTE_INPUT_NONE
+
+object AndroidKeyMapper {
+    private val inputs: Map<Key, KeyboardKey> = mapOf(
+        Key.One to KeyboardKey.ROW_1_KEY_01,
+        Key.Two to KeyboardKey.ROW_1_KEY_02,
+        Key.Three to KeyboardKey.ROW_1_KEY_03,
+        Key.Four to KeyboardKey.ROW_1_KEY_04,
+        Key.Five to KeyboardKey.ROW_1_KEY_05,
+        Key.Six to KeyboardKey.ROW_1_KEY_06,
+        Key.Seven to KeyboardKey.ROW_1_KEY_07,
+        Key.Eight to KeyboardKey.ROW_1_KEY_08,
+        Key.Nine to KeyboardKey.ROW_1_KEY_09,
+        Key.Zero to KeyboardKey.ROW_1_KEY_10,
+        Key.Minus to KeyboardKey.ROW_1_KEY_11,
+        Key.Equals to KeyboardKey.ROW_1_KEY_12,
+        Key.Grave to KeyboardKey.ROW_1_KEY_00, // `
+        Key.Q to KeyboardKey.ROW_2_KEY_00,
+        Key.W to KeyboardKey.ROW_2_KEY_01,
+        Key.E to KeyboardKey.ROW_2_KEY_02,
+        Key.R to KeyboardKey.ROW_2_KEY_03,
+        Key.T to KeyboardKey.ROW_2_KEY_04,
+        Key.Y to KeyboardKey.ROW_2_KEY_05,
+        Key.U to KeyboardKey.ROW_2_KEY_06,
+        Key.I to KeyboardKey.ROW_2_KEY_07,
+        Key.O to KeyboardKey.ROW_2_KEY_08,
+        Key.P to KeyboardKey.ROW_2_KEY_09,
+        Key.LeftBracket to KeyboardKey.ROW_2_KEY_10,
+        Key.RightBracket to KeyboardKey.ROW_2_KEY_11,
+        Key.A to KeyboardKey.ROW_3_KEY_00,
+        Key.S to KeyboardKey.ROW_3_KEY_01,
+        Key.D to KeyboardKey.ROW_3_KEY_02,
+        Key.F to KeyboardKey.ROW_3_KEY_03,
+        Key.G to KeyboardKey.ROW_3_KEY_04,
+        Key.H to KeyboardKey.ROW_3_KEY_05,
+        Key.J to KeyboardKey.ROW_3_KEY_06,
+        Key.K to KeyboardKey.ROW_3_KEY_07,
+        Key.L to KeyboardKey.ROW_3_KEY_08,
+        Key.Semicolon to KeyboardKey.ROW_3_KEY_09,
+        Key.Apostrophe to KeyboardKey.ROW_3_KEY_10,
+        Key.Backslash to KeyboardKey.ROW_3_KEY_11,
+        Key.Z to KeyboardKey.ROW_4_KEY_01,
+        Key.X to KeyboardKey.ROW_4_KEY_02,
+        Key.C to KeyboardKey.ROW_4_KEY_03,
+        Key.V to KeyboardKey.ROW_4_KEY_04,
+        Key.B to KeyboardKey.ROW_4_KEY_05,
+        Key.N to KeyboardKey.ROW_4_KEY_06,
+        Key.M to KeyboardKey.ROW_4_KEY_07,
+        Key.Comma to KeyboardKey.ROW_4_KEY_08,
+        Key.Period to KeyboardKey.ROW_4_KEY_09,
+        Key.Slash to KeyboardKey.ROW_4_KEY_10,
+        Key.F1 to KeyboardKey.KEY_F1,
+        Key.F2 to KeyboardKey.KEY_F2,
+        Key.F3 to KeyboardKey.KEY_F3,
+        Key.F4 to KeyboardKey.KEY_F4,
+        Key.F5 to KeyboardKey.KEY_F5,
+        Key.F6 to KeyboardKey.KEY_F6,
+        Key.F7 to KeyboardKey.KEY_F7,
+        Key.F8 to KeyboardKey.KEY_F8,
+        Key.F9 to KeyboardKey.KEY_F9,
+        Key.F10 to KeyboardKey.KEY_F10,
+        Key.F11 to KeyboardKey.KEY_F11,
+        Key.F12 to KeyboardKey.KEY_F12,
+
+        // control keys
+        Key.Enter to KeyboardKey.KEY_ENTER,
+        Key.Escape to KeyboardKey.KEY_ESCAPE,
+        Key.Backspace to KeyboardKey.KEY_DELETE,
+        Key.Tab to KeyboardKey.KEY_TAB,
+        Key.Spacebar to KeyboardKey.KEY_SPACE_BAR,
+        Key.DirectionRight to KeyboardKey.KEY_RIGHT_ARROW,
+        Key.DirectionLeft to KeyboardKey.KEY_LEFT_ARROW,
+        Key.DirectionDown to KeyboardKey.KEY_DOWN_ARROW,
+        Key.DirectionUp to KeyboardKey.KEY_UP_ARROW,
+        Key.PrintScreen to KeyboardKey.KEY_PRINT_SCREEN,
+
+        // modifier keys
+        Key.ShiftLeft to KeyboardKey.KEY_SHIFT_LEFT,
+        Key.ShiftRight to KeyboardKey.KEY_SHIFT_RIGHT,
+        Key.MetaLeft to KeyboardKey.KEY_META_LEFT,
+        Key.MetaRight to KeyboardKey.KEY_META_RIGHT,
+        Key.CtrlLeft to KeyboardKey.KEY_CTRL_LEFT,
+        Key.CtrlRight to KeyboardKey.KEY_CTRL_RIGHT,
+        Key.AltLeft to KeyboardKey.KEY_ALT,
+        Key.AltRight to KeyboardKey.KEY_ALT_GR,
+        
+    )
+
+    fun getLinuxKey(key: Key): ByteArray = inputs[key]?.let { byteArrayOf(0x00, it.byte) } ?: run { Log.e("getLinuxKey()", "Not found: ${(key.keyCode ushr 32).toInt()}"); REMOTE_INPUT_NONE }
+}
\ No newline at end of file
diff --git a/app/src/main/java/com/atharok/btremote/domain/entities/remoteInput/keyboard/virtualKeyboard/VirtualKeyboardLayout.kt b/app/src/main/java/com/atharok/btremote/domain/entities/remoteInput/keyboard/virtualKeyboard/VirtualKeyboardLayout.kt
index 1a7620e..24fb133 100644
--- a/app/src/main/java/com/atharok/btremote/domain/entities/remoteInput/keyboard/virtualKeyboard/VirtualKeyboardLayout.kt
+++ b/app/src/main/java/com/atharok/btremote/domain/entities/remoteInput/keyboard/virtualKeyboard/VirtualKeyboardLayout.kt
@@ -1,5 +1,6 @@
 package com.atharok.btremote.domain.entities.remoteInput.keyboard.virtualKeyboard
 
+import android.util.Log
 import com.atharok.btremote.common.utils.REMOTE_INPUT_NONE
 import com.atharok.btremote.domain.entities.remoteInput.keyboard.KeyboardKey
 
@@ -21,5 +22,5 @@ abstract class VirtualKeyboardLayout {
     protected abstract val keyboardInputs: Map<Char, ByteArray>
     protected abstract val extraInputs: Map<Char, ByteArray>
 
-    fun getKeyboardKey(key: Char): ByteArray = inputs[key] ?: REMOTE_INPUT_NONE
+    fun getKeyboardKey(key: Char): ByteArray = inputs[key] ?: run { Log.e("getKeyboardKey()", "Not found: $key for layout: ${this::class.simpleName}"); REMOTE_INPUT_NONE }
 }
