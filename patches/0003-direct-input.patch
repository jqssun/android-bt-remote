+++ b/app/src/main/java/com/atharok/btremote/ui/views/keyboard/VirtualKeyboard.kt
@@ -26,6 +26,9 @@ import androidx.compose.ui.focus.focusRequester
 import androidx.compose.ui.graphics.Color
 import androidx.compose.ui.graphics.Shape
 import androidx.compose.ui.graphics.vector.ImageVector
+import androidx.compose.ui.input.key.key
+import androidx.compose.ui.input.key.onPreviewKeyEvent
+import androidx.compose.ui.platform.LocalContext
 import androidx.compose.ui.platform.LocalLayoutDirection
 import androidx.compose.ui.res.dimensionResource
 import androidx.compose.ui.res.stringResource
@@ -35,6 +38,7 @@ import androidx.compose.ui.unit.LayoutDirection
 import com.atharok.btremote.R
 import com.atharok.btremote.common.utils.AppIcons
 import com.atharok.btremote.common.utils.REMOTE_INPUT_NONE
+import com.atharok.btremote.domain.entities.remoteInput.keyboard.AndroidKeyMapper
 import com.atharok.btremote.domain.entities.remoteInput.keyboard.virtualKeyboard.VirtualKeyboardLayout
 import com.atharok.btremote.ui.theme.dimensionElevation3
 
@@ -44,6 +48,7 @@ fun VirtualKeyboardModalBottomSheet(
     sendKeyboardKeyReport: (ByteArray) -> Unit,
     sendTextReport: (String) -> Unit,
     onShowKeyboardBottomSheetChanged: (Boolean) -> Unit,
+    virtualKeyboardLayout: VirtualKeyboardLayout,
     modifier: Modifier = Modifier
 ) {
     KeyboardModalBottomSheet(
@@ -53,6 +58,7 @@ fun VirtualKeyboardModalBottomSheet(
     ) {
         val focusRequester = remember { FocusRequester() }
         val textState = remember { mutableStateOf("") }
+        val directInputState = remember { mutableStateOf(false) }
 
         LaunchedEffect(Unit) {
             focusRequester.requestFocus()
@@ -67,6 +73,9 @@ fun VirtualKeyboardModalBottomSheet(
             },
             sendKeyboardKeyReport = sendKeyboardKeyReport,
             sendTextReport = sendTextReport,
+            directInputMode = directInputState.value,
+            onDirectInputModeChange = { directInputState.value = it },
+            virtualKeyboardLayout = virtualKeyboardLayout,
             modifier = Modifier
                 .fillMaxWidth()
                 .padding(dimensionResource(id = R.dimen.padding_medium))
@@ -83,8 +92,13 @@ private fun StatelessKeyboardView(
     onTextChange: (String) -> Unit,
     sendKeyboardKeyReport: (ByteArray) -> Unit,
     sendTextReport: (String) -> Unit,
+    directInputMode: Boolean,
+    onDirectInputModeChange: (Boolean) -> Unit,
+    virtualKeyboardLayout: VirtualKeyboardLayout,
     modifier: Modifier = Modifier
 ) {
+    val context = LocalContext.current
+
     Column(modifier = modifier) {
         Row(
             modifier = Modifier
@@ -92,13 +106,44 @@ private fun StatelessKeyboardView(
                 .padding(bottom = dimensionResource(id = R.dimen.padding_medium)),
             verticalAlignment = Alignment.CenterVertically
         ) {
+            IconButton(
+                onClick = { onDirectInputModeChange(!directInputMode) },
+                modifier = Modifier
+                    .weight(1f)
+                    .padding(end = dimensionResource(id = R.dimen.padding_min))
+            ) {
+                Icon(
+                    imageVector = AppIcons.Input,
+                    contentDescription = stringResource(id = R.string.direct_input),
+                    tint = if (directInputMode) androidx.compose.material3.MaterialTheme.colorScheme.primary else androidx.compose.material3.LocalContentColor.current
+                )
+            }
+
             TextField(
-                value = text,
-                onValueChange = onTextChange,
+                value = if (directInputMode) "" else text,
+                onValueChange = if (directInputMode) {
+                    { newText ->
+                        if (newText.isNotEmpty()) {
+                            val char = newText.last()
+                            sendKeyboardKeyReport(virtualKeyboardLayout.getKeyboardKey(char))
+                            sendKeyboardKeyReport(REMOTE_INPUT_NONE)
+                        }
+                    }
+                } else onTextChange,
                 modifier = Modifier
                     .weight(4f)
                     .padding(end = dimensionResource(id = R.dimen.padding_min))
-                    .focusRequester(focusRequester),
+                    .focusRequester(focusRequester)
+                    .onPreviewKeyEvent { keyEvent ->
+                        if (directInputMode) {
+                            val mappedKey = AndroidKeyMapper.getLinuxKey(keyEvent.key)
+                            if (mappedKey != REMOTE_INPUT_NONE) {
+                                sendKeyboardKeyReport(mappedKey)
+                                sendKeyboardKeyReport(REMOTE_INPUT_NONE)
+                                true
+                            } else false
+                        } else false
+                    },
                 keyboardOptions = KeyboardOptions.Default.copy(
                     imeAction = ImeAction.Done
                 ),
@@ -119,17 +164,21 @@ private fun StatelessKeyboardView(
             )
             IconButton(
                 onClick = {
-                    sendTextReport(text)
-                    if(mustClearInputField) {
-                        onTextChange("")
+                    if(!directInputMode) {
+                        sendTextReport(text)
+                        if(mustClearInputField) {
+                            onTextChange("")
+                        }
                     }
                 },
                 modifier = Modifier.weight(1f).padding(start = dimensionResource(id = R.dimen.padding_min))
             ) {
-                Icon(
-                    imageVector = AppIcons.Send,
-                    contentDescription = stringResource(id = R.string.send)
-                )
+                if (!directInputMode) {
+                    Icon(
+                        imageVector = AppIcons.Send,
+                        contentDescription = stringResource(id = R.string.send)
+                    )
+                }
             }
         }
 
